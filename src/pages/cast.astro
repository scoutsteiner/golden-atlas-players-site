---

<BaseLayout title="Cast" description="Meet the Golden Atlas Players cast members bringing Rocky Horror to the GAP Theatre.">
  <section class="hero cast-hero">
    <div class="hero__content">
      <span class="badge">Cast</span>
      <h1>Meet the players behind the curtain.</h1>
      <p class="section-copy">Golden Atlas Players was founded in 2025 by Clint and Emma, who wanted to create a safe and supportive community where people of all backgrounds can enjoy Rocky Horror together.</p>
      <p class="section-copy">Meet the cast members bringing the callbacks, chaos, and late-night heart to the GAP Theatre stage.</p>
    </div>
    <div class="hero__figure">
      <img
        class="hero__frank"
        src="/assets/images/cast/about-cast.jpg"
        alt="Golden Atlas Players cast and community"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <section class="cast-section" aria-labelledby="cast-heading">
    <div class="section-header">
      <span class="badge">Meet the Cast</span>
      <h2 id="cast-heading" class="section-title">Golden Atlas Players</h2>
    </div>

    <div class="cast-grid">
      {castMembers.map((member) => (
        <article class="cast-card">
          <figure class="cast-card__figure">
            <img
              class="cast-card__photo"
              src={member.image}
              alt={member.alt}
              loading="lazy"
              decoding="async"
            />
            <figcaption>
              {member.photoCreditUrl ? (
                <a href={member.photoCreditUrl} target="_blank" rel="noopener noreferrer">
                  {member.photoCredit}
                </a>
              ) : (
                member.photoCredit
              )}
            </figcaption>
          </figure>

          <div class="cast-card__body">
            <header class="cast-card__header">
              <h3>{member.stageName}</h3>
              <dl class="cast-meta">
                <div>
                  <dt>Pronouns</dt>
                  <dd>{member.pronouns}</dd>
                </div>
                <div>
                  <dt>Cast role</dt>
                  <dd>{member.castRole}</dd>
                </div>
                <div>
                  <dt>Character or usual role</dt>
                  <dd>{member.usualRole}</dd>
                </div>
              </dl>
            </header>

            <dl class="cast-qa">
              {member.questions.map(([question, answer]) => (
                <div>
                  <dt>{question}</dt>
                  <dd>{answer}</dd>
                </div>
              ))}
            </dl>

            {!!member.socialLinks?.length && (
              <div class="cast-socials">
                {member.socialLinks.map((social) => (
                  <a class="cast-social" href={social.href} target="_blank" rel="noopener noreferrer">
                    {social.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .cast-hero {
    align-items: center;
    gap: 1.5rem;
    min-width: 0;
  }

  .cast-hero .hero__figure {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .cast-hero .hero__frank {
    width: min(100%, 420px);
    max-width: 420px;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 1rem;
    border: 1px solid var(--border);
    filter: none;
    transform: none;
  }

  .cast-section {
    display: grid;
    gap: 1.25rem;
    min-width: 0;
  }

  .section-header {
    display: grid;
    gap: 0.7rem;
  }

  .cast-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    align-items: start;
    gap: 1rem;
    min-width: 0;
  }

  .cast-card {
    display: grid;
    align-content: start;
    gap: 1rem;
    height: 100%;
    min-width: 0;
    padding: clamp(1rem, 2vw, 1.25rem);
    border: 1px solid var(--border);
    border-radius: 1rem;
    background:
      linear-gradient(155deg, rgba(217, 45, 45, 0.09), rgba(255, 255, 255, 0.025) 42%),
      rgba(255, 255, 255, 0.03);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
  }

  .cast-card__figure {
    display: grid;
    justify-items: center;
    gap: 0.55rem;
    margin: 0;
    text-align: center;
  }

  .cast-card__photo {
    --photo-size: clamp(168px, 46vw, 224px);
    width: var(--photo-size);
    height: var(--photo-size);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(213, 180, 111, 0.72);
    box-shadow: 0 0 0 7px rgba(217, 45, 45, 0.12), 0 12px 26px rgba(0, 0, 0, 0.34);
  }

  .cast-card__figure figcaption {
    color: rgba(216, 198, 180, 0.72);
    font-size: 0.82rem;
    font-style: italic;
    line-height: 1.35;
  }

  .cast-card__figure figcaption a {
    color: inherit;
    text-decoration-color: rgba(216, 198, 180, 0.45);
    text-underline-offset: 0.18em;
  }

  .cast-card__figure figcaption a:hover {
    color: var(--text);
  }

  .cast-card__body,
  .cast-card__header,
  .cast-meta,
  .cast-qa {
    display: grid;
    gap: 0.85rem;
    min-width: 0;
  }

  .cast-card__header h3 {
    margin: 0;
    color: var(--text);
    font-size: clamp(1.45rem, 3vw, 1.85rem);
    line-height: 1.05;
    text-align: center;
  }

  .cast-meta,
  .cast-qa {
    margin: 0;
  }

  .cast-meta {
    gap: 0.45rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgba(213, 180, 111, 0.2);
  }

  .cast-meta div,
  .cast-qa div {
    display: grid;
    gap: 0.22rem;
  }

  .cast-meta dt,
  .cast-qa dt {
    color: var(--gold);
    font-weight: 700;
    line-height: 1.3;
  }

  .cast-meta dt {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cast-qa dt {
    font-size: 0.95rem;
  }

  .cast-meta dd,
  .cast-qa dd {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
    overflow-wrap: break-word;
  }

  .cast-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cast-social {
    justify-self: start;
    width: fit-content;
    margin-top: 0.1rem;
    padding: 0.55rem 0.78rem;
    border: 1px solid rgba(217, 45, 45, 0.4);
    border-radius: 999px;
    color: var(--text);
    font-weight: 700;
    background: rgba(217, 45, 45, 0.14);
  }

  .cast-social:hover {
    color: white;
    background: rgba(217, 45, 45, 0.24);
    transform: translateY(-1px);
  }

  @media (max-width: 760px) {
    .cast-hero {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .cast-hero .hero__frank {
      width: 100%;
      max-width: 100%;
    }

    .cast-grid {
      grid-template-columns: 1fr;
    }

    .cast-card {
      padding: 1rem;
    }
  }
</style>
