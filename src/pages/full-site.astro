---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="A warm, theatrical online home for Golden Atlas Players and Rocky Horror fans in the Slate Belt.">
  <section class="hero">
    <div class="hero__content">
      <img
        class="logo-mark"
        src="/assets/logos/Golden_Atlas_Players_Logo.png"
        alt="Golden Atlas Players logo"
        onerror="this.style.display='none'"
      />
      <h1>Golden Atlas Players</h1>
      <p class="hero__subtitle">Rocky Horror in the Slate Belt</p>
      <p class="hero__intro">A community home for Rocky Horror fans, performers, and midnight movie weirdos.</p>
      <div class="btn-row">
        <a class="btn" href="/community">Join our Discord</a>
        <a class="btn secondary" href="https://www.facebook.com/GoldenAtlasPlayers">Follow on Facebook</a>
      </div>
    </div>
    <div class="hero__figure">
      <img
        class="hero__frank"
        src="/assets/images/franknfurter/franknfurter_side_corset.png"
        alt="Frank-N-Furter"
        loading="eager"
        onerror="this.style.display='none'"
      />
    </div>
  </section>

  <section>
    <h2 class="section-title">Upcoming Shows</h2>
    <div class="card-grid">
      <article class="card">
        <h3>Midnight at the GAP</h3>
        <p>Our next Rocky Horror gathering will be announced soon with performance details and community updates.</p>
      </article>
      <article class="card">
        <h3>Join the Cast</h3>
        <p>Learn more about cast roles, character profiles, and how to get involved with the shadowcast.</p>
      </article>
      <article class="card">
        <h3>Community Nights</h3>
        <p>We’re building a welcoming home for audience members, performers, and curious first-timers.</p>
      </article>
    </div>
  </section>

  <section class="feature-section">
    <div class="feature-section__content">
      <span class="badge">Community</span>
      <h2 class="section-title">A welcoming home for Rocky Horror lovers.</h2>
      <p class="section-copy">Golden Atlas Players performs at the GAP Theatre in Wind Gap and welcomes both longtime Rocky Horror fans and complete newcomers. Our goal is to make the experience feel warm, theatrical, and rooted in local community.</p>
    </div>
    <div class="feature-section__media">
      <img
        src="/assets/images/cast/GAP_cast.jpg"
        alt="Golden Atlas Players cast photo"
        loading="lazy"
        onerror="this.parentElement.classList.add('is-image-missing')"
      />
    </div>
  </section>

  <section class="feature-section">
    <div class="feature-section__media">
      <img
        src="/assets/images/posters/theatre.jpg"
        alt="GAP Theatre"
        loading="lazy"
        onerror="this.parentElement.classList.add('is-image-missing')"
      />
    </div>
    <div class="feature-section__content">
      <span class="badge">Our Home Theatre</span>
      <h2 class="section-title">The GAP Theatre in Wind Gap.</h2>
      <p class="section-copy">The GAP Theatre is home base for our local Rocky Horror spirit. We’re proud to call Wind Gap our hometown stage and to welcome neighbors and visitors alike into the experience.</p>
    </div>
  </section>
</BaseLayout>
