---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Community" description="A welcoming place for Rocky Horror fans, performers, and audience members connected through Golden Atlas Players.">
  <section class="hero">
    <div>
      <span class="badge">Community</span>
      <h1>Connecting local Rocky Horror fans, audience members, and performers.</h1>
      <p>Our goal is to build a welcoming community around the Golden Atlas Players, whether you love the show, want to perform, or are simply curious about the strange and wonderful world of Rocky Horror.</p>
    </div>
    <div class="placeholder">Community platform placeholder</div>
  </section>

  <section>
    <div class="card-grid">
      <article class="card">
        <h3>Audience community</h3>
        <p>Share favorite moments, event reminders, and local Rocky Horror enthusiasm.</p>
      </article>
      <article class="card">
        <h3>Cast and backstage community</h3>
        <p>Connect with performers, rehearsal updates, and behind-the-scenes planning.</p>
      </article>
      <article class="card">
        <h3>Announcements</h3>
        <p>Get updates about performances, events, and new community happenings.</p>
      </article>
    </div>
  </section>

  <section class="two-col">
    <div>
      <h2 class="section-title">Where we’ll connect</h2>
      <p class="section-copy">Facebook is a great fit for folks who prefer a familiar social space, while Discord is a natural home for deeper community chat and ongoing conversation.</p>
    </div>
    <div class="info-card">
      <h3>Future community links</h3>
      <ul class="list">
        <li>Facebook community updates</li>
        <li>Discord chat and discussion</li>
        <li>Announcements and reminders</li>
      </ul>
    </div>
  </section>
</BaseLayout>
