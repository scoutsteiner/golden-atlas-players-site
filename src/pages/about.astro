import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Golden Atlas Players is a Rocky Horror shadowcast rooted in the Slate Belt and performing at the GAP Theatre in Wind Gap.">
  <section class="hero">
    <div>
      <span class="badge">About</span>
      <h1>Golden Atlas Players is a Rocky Horror shadowcast rooted in the Slate Belt.</h1>
      <p>Based at the GAP Theatre in Wind Gap, we’re building a warm local community around Rocky Horror performance, audience connection, and the joy of sharing weird, theatrical nights together.</p>
      <p>Clint and Emma lead the cast with a welcoming, community-first spirit that values both longtime fans and first-timers.</p>
    </div>
    <div class="placeholder">Theater or cast photo placeholder</div>
  </section>

  <section>
    <h2 class="section-title">What we’re building</h2>
    <p class="section-copy">We’re creating a home for local Rocky Horror fans, performer friendships, and the kind of community that grows one midnight show at a time. The goal is to keep things local, theatrical, and welcoming.</p>
    <ul class="list">
      <li>Shadowcast performances at the GAP Theatre</li>
      <li>Community connection for audiences and performers</li>
      <li>A friendly home for Slate Belt Rocky Horror fans</li>
    </ul>
  </section>
</BaseLayout>
