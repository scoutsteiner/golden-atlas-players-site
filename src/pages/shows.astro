---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Shows" description="Golden Atlas Players performs The Rocky Horror Picture Show every third Saturday of the month at 10:00 PM at the GAP Theatre in Wind Gap, PA.">
  <section class="hero">
    <div class="hero__content">
      <span class="badge">Shows</span>
      <h1>Golden Atlas Players Presents:</h1>
      <p class="section-copy">Every third Saturday at 10PM at the GAP Theatre.</p>
      <p class="section-copy">GAP Theatre<br />47 S Broadway<br />Wind Gap, PA 18091</p>
      <div class="btn-row">
        <a class="btn" href="https://www.google.com/maps/search/?api=1&query=47%20S%20Broadway%2C%20Wind%20Gap%2C%20PA%2018091" target="_blank" rel="noopener">Get Directions</a>
      </div>
    </div>
    <div class="hero__figure">
      <div class="card hero-card">
        <h2 class="section-title">The Rocky Horror Picture Show</h2>
        <p class="section-copy">A local late-night screening with a welcoming crowd, a theatrical feel, and a simple schedule that’s easy to remember.</p>
      </div>
    </div>
  </section>

  <section>
    <h2 class="section-title">Coming soon</h2>
    <p class="section-copy">Calendar updates and ticket details will be shared here as they’re confirmed.</p>
  </section>
</BaseLayout>

<style>
  .hero {
    align-items: center;
  }

  .hero-card {
    width: 100%;
    max-width: 420px;
    margin-left: auto;
  }

  .hero-card {
    max-width: 420px;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-card {
      margin-left: 0;
    }
  }
</style>
