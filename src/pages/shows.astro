---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Shows" description="Golden Atlas Players performs The Rocky Horror Picture Show every third Saturday of the month at 10:00 PM at the GAP Theatre in Wind Gap, PA.">
  <section class="hero">
    <div class="hero__content">
      <span class="badge">Shows</span>
      <h1>Golden Atlas Players Presents:</h1>
      <p class="section-copy">Every third Saturday at 10PM at the GAP Theatre.</p>
      <p class="section-copy">GAP Theatre<br />47 S Broadway<br />Wind Gap, PA 18091</p>
      <div class="btn-row">
        <a class="btn" href="https://www.google.com/maps/search/?api=1&query=47%20S%20Broadway%2C%20Wind%20Gap%2C%20PA%2018091" target="_blank" rel="noopener">Get Directions</a>
      </div>
    </div>
    <div class="hero__figure">
      <div class="card hero-card">
        <h2 class="section-title">The Rocky Horror Picture Show</h2>
        <p class="section-copy">A local late-night screening with a welcoming crowd, a theatrical feel, and a simple schedule that’s easy to remember.</p>
      </div>
    </div>
  </section>

  <section class="calendar-section">
    <h2 class="section-title">Upcoming shows</h2>
    <p class="section-copy">Check the calendar below for upcoming screenings and events.</p>
    <div class="calendar-embed">
      <iframe
        title="Golden Atlas Players calendar"
        src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FNew_York&showPrint=0&showCalendars=0&title&src=Z29sZGVuYXRsYXNwbGF5ZXJzQGdtYWlsLmNvbQ&src=ZW4udXNhI2hvbGlkYXlAZ3JvdXAudi5jYWxlbmRhci5nb29nbGUuY29t&color=%23039be5&color=%230b8043"
        frameborder="0"
        scrolling="no"
      ></iframe>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    align-items: center;
  }

  .hero-card {
    width: 100%;
    max-width: 420px;
    margin-left: auto;
  }

  .hero-card {
    max-width: 420px;
  }

  .calendar-section {
    display: grid;
    gap: 1rem;
    overflow-x: hidden;
  }

  .calendar-embed {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    box-sizing: border-box;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgba(217, 45, 45, 0.24);
    background: rgba(0, 0, 0, 0.35);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
  }

  .calendar-embed iframe {
    display: block;
    width: 100%;
    max-width: 100%;
    min-height: 600px;
    border: 0;
  }

  @media (max-width: 760px) {
    .calendar-embed iframe {
      min-height: 540px;
    }
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-card {
      margin-left: 0;
    }
  }
</style>
