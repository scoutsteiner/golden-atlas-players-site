---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Shows" description="Upcoming performances and community events from Golden Atlas Players at the GAP Theatre.">
  <section class="hero">
    <div>
      <span class="badge">Shows</span>
      <h1>Upcoming performances at the GAP Theatre.</h1>
      <p>We’re building toward future Rocky Horror screenings, themed events, and shadowcast performances in Wind Gap. These cards are placeholders for upcoming dates and details.</p>
    </div>
    <div class="placeholder">Show schedule placeholder</div>
  </section>

  <section>
    <h2 class="section-title">Coming soon</h2>
    <div class="card-grid">
      <article class="card">
        <h3>Midnight Madness</h3>
        <p>Friday · 10:00 PM · GAP Theatre</p>
        <p>First community screening and welcome event for new fans.</p>
      </article>
      <article class="card">
        <h3>Time Warp Revue</h3>
        <p>Saturday · 8:00 PM · GAP Theatre</p>
        <p>A slightly campy evening with cast updates and audience fun.</p>
      </article>
      <article class="card">
        <h3>Shadow Cast Showcase</h3>
        <p>Sunday · 7:30 PM · GAP Theatre</p>
        <p>A preview night for future performances and community outreach.</p>
      </article>
    </div>
  </section>
</BaseLayout>
