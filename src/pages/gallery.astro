---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gallery" description="Placeholder gallery for Golden Atlas Players photos and posters.">
  <section class="hero">
    <div>
      <span class="badge">Gallery</span>
      <h1>Snapshots from the shadows.</h1>
      <p>This gallery will eventually hold show photos, posters, and behind-the-scenes moments from the Golden Atlas Players.</p>
    </div>
    <div class="placeholder">Featured gallery image placeholder</div>
  </section>

  <section>
    <h2 class="section-title">Photo sections</h2>
    <div class="image-grid">
      <article class="info-card">
        <h3>Show photos</h3>
        <div class="placeholder">Show photos coming soon</div>
      </article>
      <article class="info-card">
        <h3>Posters</h3>
        <div class="placeholder">Poster gallery coming soon</div>
      </article>
      <article class="info-card">
        <h3>Behind the scenes</h3>
        <div class="placeholder">BTS gallery coming soon</div>
      </article>
    </div>
  </section>
</BaseLayout>
