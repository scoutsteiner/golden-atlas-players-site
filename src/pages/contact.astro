---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Placeholder contact information for Golden Atlas Players.">
  <section class="hero">
    <div>
      <span class="badge">Contact</span>
      <h1>Get in touch with the Golden Atlas Players.</h1>
      <p>Use this page for questions about joining the cast, community happenings, website help, or event bookings.</p>
    </div>
    <div class="placeholder">Contact form placeholder</div>
  </section>

  <section>
    <div class="card-grid">
      <article class="card">
        <h3>Joining the cast</h3>
        <p>Interested in performing, volunteering, or getting involved behind the scenes? Placeholder details coming soon.</p>
      </article>
      <article class="card">
        <h3>Audience and community questions</h3>
        <p>Questions about events, community spaces, or local Rocky Horror happenings? Placeholder details coming soon.</p>
      </article>
      <article class="card">
        <h3>Website or Discord help</h3>
        <p>Need help with the site, Discord updates, or online community links? Placeholder details coming soon.</p>
      </article>
      <article class="card">
        <h3>Booking or event inquiries</h3>
        <p>Interested in booking a show, screening, or themed event? Placeholder details coming soon.</p>
      </article>
    </div>
  </section>
</BaseLayout>
