---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact Golden Atlas Players with questions, ideas, or ways to get involved.">
  <section class="hero contact-hero">
    <div class="hero__content">
      <span class="badge">Contact</span>
      <h1>Contact Golden Atlas Players</h1>
      <p class="section-copy">Have a question, an idea, or want to get involved? Send us a message and someone from the Golden Atlas Players team will get back to you as soon as possible.</p>
    </div>
  </section>

  <section class="contact-section" aria-labelledby="contact-form-heading">
    <div class="contact-layout">
      <form class="contact-form" action="https://formspree.io/f/mzdnvkeg" method="POST">
        <div class="form-heading">
          <h2 id="contact-form-heading" class="section-title">Send a message</h2>
          <p class="section-copy"><span class="required-mark">*</span> Required fields</p>
        </div>

        <input type="hidden" name="_subject" value="New Golden Atlas Players website message" />

        <div class="honeypot" aria-hidden="true">
          <label for="contact-gotcha">Leave this field blank</label>
          <input id="contact-gotcha" type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
        </div>

        <div class="form-field">
          <label for="contact-name">Name <span aria-hidden="true">*</span></label>
          <input id="contact-name" name="name" type="text" required autocomplete="name" maxlength="150" />
        </div>

        <div class="form-field">
          <label for="contact-email">Email <span aria-hidden="true">*</span></label>
          <input id="contact-email" name="email" type="email" required autocomplete="email" maxlength="254" />
        </div>

        <div class="form-field">
          <label for="contact-subject">Subject <span aria-hidden="true">*</span></label>
          <input id="contact-subject" name="subject" type="text" required maxlength="150" />
        </div>

        <div class="form-field">
          <label for="contact-message">Message <span aria-hidden="true">*</span></label>
          <textarea id="contact-message" name="message" required maxlength="5000"></textarea>
        </div>

        <div class="btn-row">
          <button class="btn contact-submit" type="submit">Send Message</button>
        </div>
      </form>

      <aside class="contact-info" aria-label="Contact details">
        <div class="info-card">
          <h2>Looking to get involved?</h2>
          <p class="section-copy">Whether you are interested in performing, volunteering, helping behind the scenes, collaborating, or just learning more, use the form above and tell us what you have in mind.</p>
        </div>

        <div class="info-card">
          <h2>Venue</h2>
          <address>
            GAP Theatre<br />
            47 S Broadway<br />
            Wind Gap, PA 18091
          </address>
          <div class="btn-row">
            <a class="btn secondary" href="https://www.google.com/maps/search/?api=1&query=47%20S%20Broadway%2C%20Wind%20Gap%2C%20PA%2018091" target="_blank" rel="noopener noreferrer">Google Maps</a>
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    min-height: 360px;
    grid-template-columns: 1fr;
    align-items: center;
  }

  .contact-section {
    display: grid;
    gap: 1rem;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 1rem;
    align-items: start;
  }

  .contact-form,
  .contact-info {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }

  .contact-form {
    width: 100%;
    max-width: 720px;
  }

  .form-heading {
    display: grid;
    gap: 0.5rem;
  }

  .required-mark,
  .form-field label span {
    color: var(--gold);
  }

  .form-field {
    display: grid;
    gap: 0.4rem;
  }

  .form-field label {
    color: var(--gold);
    font-weight: 700;
    line-height: 1.3;
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    border: 1px solid rgba(213, 180, 111, 0.28);
    border-radius: 0.75rem;
    padding: 0.85rem 0.9rem;
    background: rgba(0, 0, 0, 0.28);
    color: var(--text);
    font: inherit;
    line-height: 1.5;
  }

  .form-field textarea {
    min-height: 180px;
    resize: vertical;
  }

  .form-field input:focus-visible,
  .form-field textarea:focus-visible,
  .contact-submit:focus-visible,
  .contact-info .btn:focus-visible {
    outline: 3px solid rgba(213, 180, 111, 0.72);
    outline-offset: 3px;
  }

  .form-field input:invalid:not(:placeholder-shown),
  .form-field textarea:invalid:not(:placeholder-shown) {
    border-color: rgba(217, 45, 45, 0.65);
  }

  .contact-submit {
    cursor: pointer;
    font: inherit;
  }

  .contact-info .info-card {
    display: grid;
    gap: 0.75rem;
  }

  .contact-info h2 {
    margin: 0;
    color: var(--text);
    font-size: 1.3rem;
    line-height: 1.2;
  }

  .contact-info address {
    color: var(--muted);
    font-style: normal;
    line-height: 1.7;
  }

  .honeypot {
    position: absolute;
    left: -100vw;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  @media (max-width: 840px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-form {
      max-width: none;
    }
  }
</style>
